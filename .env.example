# 🧠 Configuración de Entorno - OmniBrain-API

# Puerto en el que corre la API (Default: 3000)
PORT=3000

# 🔑 Proveedores de Inteligencia Artificial (AI Keys)
# 👉 NOTA: Puedes añadir MÚLTIPLES llaves separadas por COMAS para rotar si una se agota (ej. 429 Rate Limit)
# Ejemplo: GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3

# https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-tu_primera_key,sk-or-v1-tu_segunda_key_opcional

# 🔐 API Key para proteger tu Endpoint Local (Fase 2.1)
# Este es el token que deberás enviar en el Header de tus clientes (Authorization: Bearer <TOKEN>)
# 💡 TIP: Puedes generar un token seguro en una terminal Linux/WSL corriendo:
# ▶️ openssl rand -hex 32
LOCAL_API_KEY=omnibrain-dev-token

# https://console.groq.com/
GROQ_API_KEY=gsk_tu_primera_key,gsk_tu_segunda_key_opcional

# https://cloud.cerebras.ai/
# (El soporte para rotar Cerebras y OpenRouter se puede activar si se desea)
CEREBRAS_API_KEY=csk-tu_key_principal

# https://api.z.ai/
ZAI_API_KEY=tu_primera_key_zai,tu_segunda_key_zai_opcional

# 🗄️ Base de datos (SQLite)
DATABASE_URL=./data/api.db

# 🛡️ Seguridad y Control
ENABLE_CORS=true
CORS_ORIGINS=*

# 📜 Nivel de Logs (debug, info, warn, error)
LOG_LEVEL=debug
